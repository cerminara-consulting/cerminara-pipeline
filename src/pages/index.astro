---
// Cerminara Pipeline Tracker — main dashboard.
// Classic Mac (System 7) aesthetic. Single-page, client-rendered,
// mobile shows card list, desktop shows kanban with drag-and-drop.
//
// The page itself is one "window" (the application). Sections inside
// it are smaller windows with their own title bars, in the classic
// "multiple windows on the desktop" idiom.
import '../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>Pipeline — Tracker</title>
</head>
<body>
  <!-- Auth view (shown when signed out) -->
  <div id="auth-view" style="display:none">
    <!-- Menu bar always shown, even when signed out, so the chrome is consistent -->
    <div id="menubar" role="menubar" aria-label="Application menu">
      <div class="mb-appname">Tracker</div>
      <button class="mb-item right" type="button">No user</button>
    </div>
    <div class="app-body">
      <div class="auth-shell">
        <div class="window auth-window">
          <div class="titlebar">
            <div class="titlebar-text">Sign in to Tracker</div>
          </div>
          <div class="window-body">
            <div class="sub">Solo-operator CRM · Cerminara Consulting</div>

            <div class="tabs" id="auth-tabs">
              <button type="button" data-tab="password" class="active">Password</button>
              <button type="button" data-tab="magic">Magic link</button>
            </div>

            <form id="auth-form">
              <label for="email">Email</label>
              <input id="email" type="email" autocomplete="email" required />

              <div id="password-field">
                <label for="password">Password (12+ characters)</label>
                <input id="password" type="password" autocomplete="current-password" minlength="12" required />
              </div>

              <button type="submit" class="primary submit" id="auth-submit">Sign in</button>
              <div id="auth-msg" class="auth-msg" style="display:none"></div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Dashboard view (shown when signed in) -->
  <div id="dash-view" style="display:none">
    <div id="menubar" role="menubar" aria-label="Application menu">
      <div class="mb-appname">Tracker</div>
      <button class="mb-item" data-menu="file" type="button">File</button>
      <button class="mb-item" data-menu="edit" type="button">Edit</button>
      <button class="mb-item" data-menu="view" type="button">View</button>
      <button class="mb-item" data-menu="help" type="button">Help</button>
      <button class="mb-item right" type="button" id="mb-user">—</button>
      <button class="mb-item" type="button" id="mb-signout">Sign out</button>

      <div class="mb-dropdown" id="dd-file">
        <button class="mb-di" data-action="new-engagement">New engagement…</button>
        <button class="mb-di" data-action="export">Export data…</button>
      </div>
      <div class="mb-dropdown" id="dd-edit">
        <button class="mb-di" disabled>Undo</button>
        <button class="mb-di" disabled>Cut</button>
        <button class="mb-di" disabled>Copy</button>
        <button class="mb-di" disabled>Paste</button>
        <button class="mb-di" disabled>Clear</button>
      </div>
      <div class="mb-dropdown" id="dd-view">
        <button class="mb-di" data-action="view-mobile">Card list (mobile)</button>
        <button class="mb-di" data-action="view-desktop">Pipeline board</button>
      </div>
      <div class="mb-dropdown" id="dd-help">
        <button class="mb-di" data-action="about">About Tracker…</button>
        <button class="mb-di" data-action="shortcuts">Keyboard shortcuts…</button>
      </div>
    </div>

    <div class="app-body">
      <!-- Summary "panels" — small windows with their own title bars -->
      <div class="window">
        <div class="titlebar">
          <div class="titlebar-text">Overview</div>
        </div>
        <div class="window-body" style="padding:8px">
          <div class="summary-bar" id="summary">
            <div class="summary-card">
              <div class="label">Active</div>
              <div class="value" id="m-active">—</div>
            </div>
            <div class="summary-card">
              <div class="label">Quoted</div>
              <div class="value" id="m-quoted">—</div>
            </div>
            <div class="summary-card due">
              <div class="label">Outstanding</div>
              <div class="value" id="m-outstanding">—</div>
            </div>
            <div class="summary-card">
              <div class="label">Paid total</div>
              <div class="value" id="m-paid">—</div>
            </div>
            <div class="summary-card due">
              <div class="label">Follow-ups due</div>
              <div class="value" id="m-followups">—</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile: card list window -->
      <div class="window mobile-only">
        <div class="titlebar">
          <div class="titlebar-text">All engagements</div>
        </div>
        <div class="window-body" style="padding:8px">
          <div class="list-toolbar">
            <h2>Tap a card to edit</h2>
            <div class="actions">
              <button id="new-mobile" class="primary">+ New</button>
            </div>
          </div>
          <div class="card-list" id="card-list"></div>
        </div>
      </div>

      <!-- Desktop: kanban window -->
      <div class="window desktop-only">
        <div class="titlebar">
          <div class="titlebar-text">Pipeline board</div>
        </div>
        <div class="window-body" style="padding:8px">
          <div class="list-toolbar">
            <h2>Drag cards between columns</h2>
            <div class="actions">
              <button id="new-desktop" class="primary">+ New engagement</button>
            </div>
          </div>
          <div class="kanban" id="kanban"></div>
        </div>
      </div>

      <!-- Status bar at the bottom (Mac OS had these) -->
      <div id="statusbar" style="margin-top:8px;border:var(--border-thick);background:var(--p);padding:5px 10px;font-size:11px;display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap">
        <span><span id="s-counts">0 engagements</span></span>
        <span><span id="s-lastact">No activity yet</span></span>
        <span class="desktop-only">⌘N new · Esc close · Drag to move</span>
      </div>
    </div>

    <!-- Detail drawer (window) -->
    <div class="drawer-backdrop" id="drawer-backdrop" style="display:none">
      <div class="drawer">
        <div class="window">
          <div class="titlebar">
            <div class="closebox" id="drawer-close" aria-label="Close">×</div>
            <div class="titlebar-text" id="drawer-title">Engagement</div>
          </div>
          <div class="window-body" id="drawer"></div>
        </div>
      </div>
    </div>

    <!-- New engagement drawer -->
    <div class="drawer-backdrop" id="new-backdrop" style="display:none">
      <div class="drawer">
        <div class="window">
          <div class="titlebar">
            <div class="closebox" id="new-close" aria-label="Close">×</div>
            <div class="titlebar-text">New engagement</div>
          </div>
          <div class="window-body" id="new-drawer"></div>
        </div>
      </div>
    </div>

    <!-- About modal (Mac-style alert) -->
    <div class="drawer-backdrop" id="about-backdrop" style="display:none;align-items:center;justify-content:center">
      <div class="window" style="width:100%;max-width:380px;margin:0">
        <div class="titlebar">
          <div class="titlebar-text">About Tracker</div>
        </div>
        <div class="window-body" style="text-align:center">
          <!-- 1-bit Mac-style logo: stack of horizontal bars -->
          <svg width="56" height="56" viewBox="0 0 56 56" style="margin:6px auto 10px;display:block">
            <rect x="6"  y="10" width="44" height="4" fill="#1a1a1a"/>
            <rect x="6"  y="20" width="44" height="4" fill="#1a1a1a"/>
            <rect x="6"  y="30" width="44" height="4" fill="#1a1a1a"/>
            <rect x="6"  y="40" width="44" height="4" fill="#1a1a1a"/>
            <rect x="6"  y="50" width="14" height="4" fill="#1a1a1a"/>
            <rect x="26" y="50" width="14" height="4" fill="#1a1a1a"/>
          </svg>
          <div style="font-weight:700;margin-bottom:6px">Cerminara Pipeline Tracker</div>
          <div style="font-size:11px;margin-bottom:10px">Version 0.1.0 · Built 2026-07-23</div>
          <div style="font-size:12px;line-height:1.5">
            A solo-operator CRM for consulting engagements.<br/>
            Astro + Supabase + 1-bit System 7 chrome.
          </div>
          <hr/>
          <div style="font-size:11px">A Cerminara Consulting build.</div>
          <div style="margin-top:12px;display:flex;justify-content:center;gap:8px">
            <button id="about-close">OK</button>
          </div>
        </div>
      </div>
    </div>

    <div class="toast" id="toast" style="display:none"></div>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';
    import {
      PIPELINE_STATUSES, STATUS_LABELS, TYPE_LABELS,
      fmtMoney, fmtRelative, fmtFollowup,
    } from '../lib/supabase';

    const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
      auth: { persistSession: true, autoRefreshToken: true, storage: localStorage },
    });

    let engagements = [];
    let clients = [];

    const authView = document.getElementById('auth-view');
    const dashView = document.getElementById('dash-view');

    async function routeByAuth() {
      const { data: { session } } = await supabase.auth.getSession();
      if (session) {
        authView.style.display = 'none';
        dashView.style.display = '';
        document.getElementById('mb-user').textContent = session.user.email;
        await loadAll();
      } else {
        authView.style.display = '';
        dashView.style.display = 'none';
      }
    }
    routeByAuth();

    supabase.auth.onAuthStateChange((_event, session) => {
      if (session) routeByAuth();
      else { authView.style.display = ''; dashView.style.display = 'none'; }
    });

    // ─── Auth UI ─────────────────────────────────────────
    const authTabs = document.getElementById('auth-tabs');
    const passwordField = document.getElementById('password-field');
    const authSubmit = document.getElementById('auth-submit');
    const authMsg = document.getElementById('auth-msg');
    let authTab = 'password';

    function setAuthMsg(text, kind) {
      authMsg.className = 'auth-msg ' + (kind || '');
      // For errors, wrap in platinum knockout over dither (classic Mac alert look)
      if (kind === 'error') {
        authMsg.innerHTML = '<span>' + escapeHtml(text) + '</span>';
      } else {
        authMsg.textContent = text;
      }
      authMsg.style.display = '';
    }

    authTabs.addEventListener('click', e => {
      const btn = e.target.closest('button[data-tab]');
      if (!btn) return;
      [...authTabs.querySelectorAll('button')].forEach(b => b.classList.toggle('active', b === btn));
      authTab = btn.dataset.tab;
      passwordField.style.display = authTab === 'password' ? '' : 'none';
      authSubmit.textContent = authTab === 'magic' ? 'Email me a link' : 'Sign in';
    });

    document.getElementById('auth-form').addEventListener('submit', async e => {
      e.preventDefault();
      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      authSubmit.disabled = true;
      authSubmit.textContent = 'Working…';
      try {
        if (authTab === 'magic') {
          const { error } = await supabase.auth.signInWithOtp({ email, options: { emailRedirectTo: location.origin } });
          if (error) throw error;
          setAuthMsg('Check your email — magic link sent.', 'success');
        } else {
          const { error } = await supabase.auth.signInWithPassword({ email, password });
          if (error) throw error;
        }
      } catch (err) {
        setAuthMsg(err.message || String(err), 'error');
      } finally {
        authSubmit.disabled = false;
        authSubmit.textContent = authTab === 'magic' ? 'Email me a link' : 'Sign in';
      }
    });

    document.getElementById('mb-signout').addEventListener('click', async () => {
      await supabase.auth.signOut();
    });

    // ─── Menu bar (real, working dropdowns) ──────────────
    const mbItems = document.querySelectorAll('.mb-item[data-menu]');
    const dropdowns = {};
    document.querySelectorAll('.mb-dropdown').forEach(dd => {
      dropdowns[dd.id.replace('dd-', '')] = dd;
    });
    let openMenu = null;
    function closeAllMenus() {
      document.querySelectorAll('.mb-dropdown.show').forEach(d => d.classList.remove('show'));
      document.querySelectorAll('.mb-item.open').forEach(b => b.classList.remove('open'));
      openMenu = null;
    }
    mbItems.forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        const name = btn.dataset.menu;
        const dd = dropdowns[name];
        if (openMenu === name) { closeAllMenus(); return; }
        closeAllMenus();
        dd.classList.add('show');
        btn.classList.add('open');
        // Position dropdown under the button
        const r = btn.getBoundingClientRect();
        dd.style.left = r.left + 'px';
        openMenu = name;
      });
    });
    document.addEventListener('click', e => {
      if (openMenu && !e.target.closest('.mb-dropdown')) closeAllMenus();
    });
    // Menu actions
    document.querySelectorAll('.mb-di[data-action]').forEach(di => {
      di.addEventListener('click', () => {
        const action = di.dataset.action;
        closeAllMenus();
        if (action === 'new-engagement') openNew();
        else if (action === 'view-mobile') { window.scrollTo(0,0); }
        else if (action === 'view-desktop') { window.scrollTo(0,0); }
        else if (action === 'about') document.getElementById('about-backdrop').style.display = 'flex';
        else if (action === 'shortcuts') {
          document.getElementById('about-backdrop').style.display = 'flex';
        }
      });
    });
    document.getElementById('about-close').addEventListener('click', () => {
      document.getElementById('about-backdrop').style.display = 'none';
    });
    document.getElementById('about-backdrop').addEventListener('click', e => {
      if (e.target.id === 'about-backdrop') document.getElementById('about-backdrop').style.display = 'none';
    });

    // ─── Data ────────────────────────────────────────────
    async function loadAll() {
      const [{ data: e }, { data: c }] = await Promise.all([
        supabase.from('engagement_summary').select('*').order('updated_at', { ascending: false }),
        supabase.from('clients').select('*').order('name'),
      ]);
      engagements = e || [];
      clients = c || [];
      render();
    }

    function renderSummary() {
      const active   = engagements.filter(e => e.status === 'active').length;
      const quoted   = engagements.filter(e => e.status === 'quoted').length;
      const paid     = engagements.reduce((s, e) => s + (e.paid_amount || 0), 0);
      const outstand = engagements.reduce((s, e) => s + (e.invoiced_amount || 0) - (e.paid_amount || 0), 0);
      const now = Date.now();
      const dueSoon = engagements.filter(e => e.next_followup_at && new Date(e.next_followup_at).getTime() <= now).length;

      document.getElementById('m-active').textContent     = active;
      document.getElementById('m-quoted').textContent     = quoted;
      document.getElementById('m-outstanding').textContent= fmtMoney(outstand);
      document.getElementById('m-paid').textContent       = fmtMoney(paid);
      document.getElementById('m-followups').textContent  = dueSoon;

      // status bar
      const total = engagements.filter(e => e.status !== 'lost').length;
      document.getElementById('s-counts').textContent = `${total} engagement${total===1?'':'s'}`;
      const last = engagements.reduce((acc, e) => {
        if (!e.last_activity_at) return acc;
        return !acc || new Date(e.last_activity_at) > new Date(acc) ? e.last_activity_at : acc;
      }, null);
      document.getElementById('s-lastact').textContent = last ? `Last activity ${fmtRelative(last)}` : 'No activity yet';
    }

    function renderCardList() {
      const list = document.getElementById('card-list');
      const visible = engagements.filter(e => e.status !== 'lost');
      if (visible.length === 0) {
        list.innerHTML = `
          <div class="empty">
            <div class="em-title">No engagements yet</div>
            <div>Tap "+ New" to add your first client + engagement.<br/>Or use File ▸ New engagement…</div>
          </div>`;
        return;
      }
      list.innerHTML = visible.map(cardHtml).join('');
      [...list.querySelectorAll('.card')].forEach(el => el.addEventListener('click', () => openDrawer(el.dataset.id)));
    }

    function cardHtml(e) {
      const now = Date.now();
      const fu = e.next_followup_at ? new Date(e.next_followup_at).getTime() : null;
      let fuClass = 'followup';
      let fuText = '';
      if (fu !== null) {
        const diffH = (fu - now) / 3600000;
        fuText = `Follow-up: ${fmtFollowup(e.next_followup_at)}`;
        if (fu < now) fuClass += ' overdue';
        else if (diffH < 48) fuClass += '';
      }
      const amount = (e.status === 'paid' || e.status === 'invoiced' || e.status === 'closed')
        ? fmtMoney(e.paid_amount || e.quoted_amount)
        : (e.quoted_amount ? fmtMoney(e.quoted_amount) : TYPE_LABELS[e.type]);
      const pillInner = e.status === 'invoiced' ? `<span>${STATUS_LABELS[e.status]}</span>` : STATUS_LABELS[e.status];
      return `
        <div class="card" data-id="${e.id}">
          <div class="row1">
            <div class="client">${escapeHtml(e.client_name)}${e.client_company ? ' · ' + escapeHtml(e.client_company) : ''}</div>
            <span class="pill s-${e.status}">${pillInner}</span>
          </div>
          <div class="name">${escapeHtml(e.name)}</div>
          <div class="meta">
            <span class="amount">${amount}</span>
            <span>·</span>
            <span>${TYPE_LABELS[e.type]}</span>
            ${e.last_activity_at ? `<span>·</span><span>${fmtRelative(e.last_activity_at)}</span>` : ''}
          </div>
          ${fuText ? `<div class="${fuClass}">${fuText}</div>` : ''}
        </div>`;
    }

    function renderKanban() {
      const board = document.getElementById('kanban');
      board.innerHTML = PIPELINE_STATUSES.map(st => {
        const inCol = engagements.filter(e => e.status === st);
        return `
          <div class="kanban-col" data-status="${st}">
            <div class="col-head"><span>${STATUS_LABELS[st]}</span><span class="col-count">${inCol.length}</span></div>
            ${inCol.map(e => `
              <div class="kanban-card" draggable="true" data-id="${e.id}">
                <div class="kc-client">${escapeHtml(e.client_name)}</div>
                <div class="kc-name">${escapeHtml(e.name)}</div>
                <div class="kc-bottom">
                  <span>${TYPE_LABELS[e.type]}</span>
                  <span>${e.quoted_amount ? fmtMoney(e.quoted_amount) : ''}</span>
                </div>
              </div>`).join('')}
          </div>`;
      }).join('');

      [...board.querySelectorAll('.kanban-col')].forEach(col => {
        col.addEventListener('dragover', e => { e.preventDefault(); col.classList.add('drag-over'); });
        col.addEventListener('dragleave', () => col.classList.remove('drag-over'));
        col.addEventListener('drop', async e => {
          e.preventDefault();
          col.classList.remove('drag-over');
          const id = e.dataTransfer.getData('text/plain');
          if (!id) return;
          await changeStatus(id, col.dataset.status);
        });
      });
      [...board.querySelectorAll('.kanban-card')].forEach(card => {
        card.addEventListener('dragstart', e => { e.dataTransfer.setData('text/plain', card.dataset.id); card.classList.add('dragging'); });
        card.addEventListener('dragend', () => card.classList.remove('dragging'));
        card.addEventListener('click', () => openDrawer(card.dataset.id));
      });
    }

    async function changeStatus(id, newStatus) {
      const e = engagements.find(x => x.id === id);
      if (!e || e.status === newStatus) return;
      const { error } = await supabase.from('engagements').update({ status: newStatus }).eq('id', id);
      if (error) { toast('Could not move: ' + error.message); return; }
      e.status = newStatus;
      render();
      toast('Moved to ' + STATUS_LABELS[newStatus]);
    }

    // ─── Detail drawer ───────────────────────────────────
    function openDrawer(id) {
      const e = engagements.find(x => x.id === id);
      if (!e) return;
      const drawer = document.getElementById('drawer');
      document.getElementById('drawer-title').textContent = e.name;
      drawer.innerHTML = `
        <div class="sub">${escapeHtml(e.client_name)}${e.client_company ? ' · ' + escapeHtml(e.client_company) : ''}</div>

        <div class="field-row">
          <div>
            <label>Status</label>
            <select id="d-status">
              ${['lead','quoted','active','invoiced','paid','closed','lost'].map(s =>
                `<option value="${s}" ${e.status===s?'selected':''}>${STATUS_LABELS[s]}</option>`).join('')}
            </select>
          </div>
          <div>
            <label>Type</label>
            <select id="d-type">
              ${['fixed','retainer','hourly'].map(t =>
                `<option value="${t}" ${e.type===t?'selected':''}>${TYPE_LABELS[t]}</option>`).join('')}
            </select>
          </div>
        </div>

        <div class="field-row">
          <div>
            <label>Quoted amount (USD)</label>
            <input id="d-amount" type="number" step="0.01" value="${e.quoted_amount ?? ''}" />
          </div>
          <div>
            <label>Hourly rate (USD)</label>
            <input id="d-rate" type="number" step="0.01" value="${e.hourly_rate ?? ''}" />
          </div>
        </div>

        <div>
          <label>Next follow-up</label>
          <input id="d-followup" type="datetime-local" value="${toLocalDT(e.next_followup_at)}" />
        </div>

        <div>
          <label>Notes</label>
          <textarea id="d-notes" rows="5">${escapeHtml(e.notes || '')}</textarea>
        </div>

        <div class="drawer-actions">
          <button class="danger" id="d-delete">Delete</button>
          <div style="display:flex;gap:8px">
            <button id="d-cancel">Close</button>
            <button class="primary" id="d-save">Save</button>
          </div>
        </div>`;

      document.getElementById('drawer-backdrop').style.display = '';
      // Flash the window chrome on open
      const win = document.querySelector('#drawer-backdrop .window');
      win.classList.add('inverted-flash');
      setTimeout(() => win.classList.remove('inverted-flash'), 160);

      document.getElementById('drawer-close').onclick = closeDrawer;
      document.getElementById('d-cancel').onclick = closeDrawer;
      document.getElementById('d-save').onclick = async () => {
        const patch = {
          status: document.getElementById('d-status').value,
          type: document.getElementById('d-type').value,
          quoted_amount: parseFloatOrNull(document.getElementById('d-amount').value),
          hourly_rate: parseFloatOrNull(document.getElementById('d-rate').value),
          next_followup_at: localDTToISO(document.getElementById('d-followup').value),
          notes: document.getElementById('d-notes').value || null,
        };
        const { error } = await supabase.from('engagements').update(patch).eq('id', id);
        if (error) { toast('Save failed: ' + error.message); return; }
        toast('Saved');
        await loadAll();
        closeDrawer();
      };
      document.getElementById('d-delete').onclick = async () => {
        if (!confirm('Delete this engagement? Activity log will be retained.')) return;
        const { error } = await supabase.from('engagements').delete().eq('id', id);
        if (error) { toast('Delete failed: ' + error.message); return; }
        toast('Deleted');
        await loadAll();
        closeDrawer();
      };
    }
    function closeDrawer() { document.getElementById('drawer-backdrop').style.display = 'none'; }
    document.getElementById('drawer-backdrop').addEventListener('click', e => {
      if (e.target.id === 'drawer-backdrop') closeDrawer();
    });

    // ─── New engagement ──────────────────────────────────
    function openNew() {
      const drawer = document.getElementById('new-drawer');
      drawer.innerHTML = `
        <div class="sub">Add a client and an engagement in one step.</div>

        <div>
          <label>Client</label>
          <select id="n-client">
            <option value="">— pick existing or new below —</option>
            ${clients.map(c => `<option value="${c.id}">${escapeHtml(c.name)}${c.company ? ' · '+escapeHtml(c.company) : ''}</option>`).join('')}
          </select>
        </div>

        <div class="field-row">
          <div>
            <label>New client name</label>
            <input id="n-client-name" placeholder="Or pick existing above" />
          </div>
          <div>
            <label>Company</label>
            <input id="n-client-co" />
          </div>
        </div>

        <div>
          <label>Client email</label>
          <input id="n-client-email" type="email" />
        </div>

        <hr/>

        <div>
          <label>Engagement name</label>
          <input id="n-name" placeholder="e.g. iOS app v2 rebuild" />
        </div>

        <div class="field-row">
          <div>
            <label>Type</label>
            <select id="n-type">
              <option value="fixed">Fixed bid</option>
              <option value="retainer">Retainer</option>
              <option value="hourly">Hourly</option>
            </select>
          </div>
          <div>
            <label>Status</label>
            <select id="n-status">
              <option value="lead">Lead</option>
              <option value="quoted">Quoted</option>
              <option value="active">Active</option>
            </select>
          </div>
        </div>

        <div>
          <label>Quoted amount (USD)</label>
          <input id="n-amount" type="number" step="0.01" placeholder="optional" />
        </div>

        <div class="drawer-actions">
          <button id="n-cancel">Cancel</button>
          <button class="primary" id="n-save">Create</button>
        </div>`;

      document.getElementById('new-backdrop').style.display = '';
      const win = document.querySelector('#new-backdrop .window');
      win.classList.add('inverted-flash');
      setTimeout(() => win.classList.remove('inverted-flash'), 160);

      document.getElementById('new-close').onclick = () => { document.getElementById('new-backdrop').style.display = 'none'; };
      document.getElementById('n-cancel').onclick = () => { document.getElementById('new-backdrop').style.display = 'none'; };
      document.getElementById('n-save').onclick = async () => {
        const name = document.getElementById('n-name').value.trim();
        if (!name) { toast('Engagement name required'); return; }
        const { data: { user } } = await supabase.auth.getUser();

        let clientId = document.getElementById('n-client').value;
        if (!clientId) {
          const clientName = document.getElementById('n-client-name').value.trim();
          if (!clientName) { toast('Pick or name a client'); return; }
          const { data: c, error: ce } = await supabase.from('clients').insert({
            owner_id: user.id,
            name: clientName,
            company: document.getElementById('n-client-co').value.trim() || null,
            email: document.getElementById('n-client-email').value.trim() || null,
          }).select().single();
          if (ce) { toast('Client create failed: ' + ce.message); return; }
          clientId = c.id;
        }

        const { error: ee } = await supabase.from('engagements').insert({
          owner_id: user.id,
          client_id: clientId,
          name,
          type: document.getElementById('n-type').value,
          status: document.getElementById('n-status').value,
          quoted_amount: parseFloatOrNull(document.getElementById('n-amount').value),
        });
        if (ee) { toast('Engagement create failed: ' + ee.message); return; }
        document.getElementById('new-backdrop').style.display = 'none';
        toast('Engagement created');
        await loadAll();
      };
    }
    document.getElementById('new-mobile').onclick = openNew;
    document.getElementById('new-desktop').onclick = openNew;
    document.getElementById('new-backdrop').addEventListener('click', e => { if (e.target.id === 'new-backdrop') document.getElementById('new-backdrop').style.display = 'none'; });

    // ─── Keyboard shortcuts ──────────────────────────────
    document.addEventListener('keydown', e => {
      // Esc closes any open drawer/modal
      if (e.key === 'Escape') {
        if (document.getElementById('drawer-backdrop').style.display !== 'none') closeDrawer();
        else if (document.getElementById('new-backdrop').style.display !== 'none') document.getElementById('new-backdrop').style.display = 'none';
        else if (document.getElementById('about-backdrop').style.display !== 'none') document.getElementById('about-backdrop').style.display = 'none';
        else closeAllMenus();
      }
      // Cmd/Ctrl+N opens new
      if ((e.metaKey || e.ctrlKey) && e.key === 'n') { e.preventDefault(); openNew(); }
    });

    function render() { renderSummary(); renderCardList(); renderKanban(); }

    function escapeHtml(s) {
      return String(s ?? '')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
    function parseFloatOrNull(v) {
      if (v === '' || v === null || v === undefined) return null;
      const n = parseFloat(v);
      return isNaN(n) ? null : n;
    }
    function toLocalDT(iso) {
      if (!iso) return '';
      const d = new Date(iso);
      const pad = n => String(n).padStart(2,'0');
      return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }
    function localDTToISO(v) {
      if (!v) return null;
      return new Date(v).toISOString();
    }
    let toastTimer;
    function toast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.style.display = '';
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => t.style.display = 'none', 2200);
    }
  </script>
</body>
</html>